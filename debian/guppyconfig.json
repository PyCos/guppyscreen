{
  "config_path": "/usr/data/guppyscreen/guppyconfig.json",
  "default_printer": "k1",
  "display_rotate": 3,
  "display_sleep_sec": 300,
  "guppy_init_script": "/etc/init.d/S99guppyscreen",
  "invert_z_direction": true,
  "log_path": "/usr/data/printer_data/logs/guppyscreen.log",
  "printers": {
    "k1": {
      "default_macros": {
        "cooldown": "_GUPPY_COOLDOWN",
        "cooldown_backup": "SET_HEATER_TEMPERATURE HEATER=extruder TARGET=0\nSET_HEATER_TEMPERATURE HEATER=heater_bed TARGET=0",
        "load_filament": "_GUPPY_LOAD_MATERIAL",
        "unload_filament": "_GUPPY_QUIT_MATERIAL"
      },
      "fans": [
        {
          "display_name": "Toolhead Fan",
          "id": "output_pin fan0"
        },
        {
          "display_name": "Back Fan",
          "id": "output_pin fan1"
        },
        {
          "display_name": "Side Fan",
          "id": "output_pin fan2"
        }
      ],
      "leds": null,
      "log_level": "debug",
      "monitored_sensors": [
        {
          "color": "red",
          "controllable": true,
          "display_name": "Extruder",
          "id": "extruder"
        },
        {
          "color": "purple",
          "controllable": true,
          "display_name": "Bed",
          "id": "heater_bed"
        },
        {
          "color": "blue",
          "controllable": false,
          "display_name": "Chamber",
          "id": "temperature_sensor chamber_temp"
        }
      ],
      "moonraker_api_key": false,
      "moonraker_host": "127.0.0.1",
      "moonraker_port": 7125
    }
  },
  "prompt_emergency_stop": true,
  "theme": null,
  "thumbnail_path": "/usr/data/printer_data/thumbnails",
  "touch_calibrated": false,
  "wpa_supplicant": "/var/run/wpa_supplicant"
}
